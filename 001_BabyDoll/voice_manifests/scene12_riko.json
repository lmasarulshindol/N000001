  "items": [
    {
      "line_index": 1,
      "role": "riko",
      "text": "……蓮……？　なんで",
      "skip_synthesis": false,
      "novel_line": 1661,
      "note": ""
    },
    {
      "line_index": 2,
      "role": "riko",
      "text": "……眠れなくて。隣、いい？",
      "skip_synthesis": false,
      "novel_line": 1665,
      "note": ""
    },
    {
      "line_index": 3,
      "role": "riko",
      "text": "……蓮、緊張してる？",
      "skip_synthesis": false,
      "novel_line": 1673,
      "note": ""
    },
    {
      "line_index": 4,
      "role": "riko",
      "text": "……してない",
      "skip_synthesis": false,
      "novel_line": 1675,
      "note": ""
    },
    {
      "line_index": 5,
      "role": "riko",
      "text": "してるじゃん。声、ちっちゃいもん",
      "skip_synthesis": false,
      "novel_line": 1677,
      "note": ""
    },
    {
      "line_index": 6,
      "role": "riko",
      "text": "……昼間は周りに人がいるから。ノリで行ける。でも——二人だと、なんか",
      "skip_synthesis": false,
      "novel_line": 1681,
      "note": ""
    },
    {
      "line_index": 7,
      "role": "riko",
      "text": "……あたしから、してもいい？",
      "skip_synthesis": false,
      "novel_line": 1699,
      "note": ""
    },
    {
      "line_index": 8,
      "role": "riko",
      "text": "あたし、蓮の、欲しい",
      "skip_synthesis": false,
      "novel_line": 1703,
      "note": ""
    },
    {
      "line_index": 9,
      "role": "riko",
      "text": "あたしが動くから。蓮は、寝てて",
      "skip_synthesis": false,
      "novel_line": 1717,
      "note": ""
    },
    {
      "line_index": 10,
      "role": "riko",
      "text": "ん……ぁ……入った。あたしから、入れたの……はじめて",
      "skip_synthesis": false,
      "novel_line": 1721,
      "note": ""
    },
    {
      "line_index": 11,
      "role": "riko",
      "text": "……蓮、こんな顔するんだ。やさしい顔",
      "skip_synthesis": false,
      "novel_line": 1729,
      "note": ""
    },
    {
      "line_index": 12,
      "role": "riko",
      "text": "……うるさい。暗くて見えねぇだろ",
      "skip_synthesis": false,
      "novel_line": 1731,
      "note": ""
    },
    {
      "line_index": 13,
      "role": "riko",
      "text": "見えなくても、分かるよ",
      "skip_synthesis": false,
      "novel_line": 1735,
      "note": ""
    },
    {
      "line_index": 14,
      "role": "riko",
      "text": "ん……蓮……きもちいい。あたしが動くの、きもちいい",
      "skip_synthesis": false,
      "novel_line": 1739,
      "note": ""
    },
    {
      "line_index": 15,
      "role": "riko",
      "text": "あ……蓮……もう……中に出して……蓮ので、あたしの中、いっぱいにして",
      "skip_synthesis": false,
      "novel_line": 1745,
      "note": ""
    },
    {
      "line_index": 16,
      "role": "other",
      "text": "……うん。出す。莉子の中に",
      "skip_synthesis": true,
      "novel_line": 1749,
      "note": "非莉子セリフ（スキップ）"
    },
    {
      "line_index": 17,
      "role": "riko",
      "text": "あ……蓮……一緒に……一緒にイく……ね",
      "skip_synthesis": false,
      "novel_line": 1753,
      "note": ""
    },
    {
      "line_index": 18,
      "role": "riko",
      "text": "ん……あったかい。蓮の……あたしの中に",
      "skip_synthesis": false,
      "novel_line": 1761,
      "note": ""
    },
    {
      "line_index": 19,
      "role": "other",
      "text": "……莉子",
      "skip_synthesis": true,
      "novel_line": 1765,
      "note": "非莉子セリフ（スキップ）"
    },
    {
      "line_index": 20,
      "role": "riko",
      "text": "ん？",
      "skip_synthesis": false,
      "novel_line": 1767,
      "note": ""
    },
    {
      "line_index": 21,
      "role": "other",
      "text": "……ありがとう",
      "skip_synthesis": true,
      "novel_line": 1769,
      "note": "非莉子セリフ（スキップ）"
    },
    {
      "line_index": 22,
      "role": "riko",
      "text": "なに、それ。お礼言うようなことじゃないでしょ",
      "skip_synthesis": false,
      "novel_line": 1771,
      "note": ""
    },
    {
      "line_index": 23,
      "role": "riko",
      "text": "……でも。ありがとう",
      "skip_synthesis": false,
      "novel_line": 1773,
      "note": ""
    },
    {
      "line_index": 24,
      "role": "riko",
      "text": "……おやすみ、蓮くん",
      "skip_synthesis": false,
      "novel_line": 1777,
      "note": ""
    },
    {
      "line_index": 25,
      "role": "other",
      "text": "……おやすみ、莉子",
      "skip_synthesis": true,
