      "novel_line": 1563,
      "note": ""
    },
    {
      "line_index": 8,
      "role": "riko",
      "text": "いっぱい……あたしの中に……ね、ね",
      "skip_synthesis": false,
      "novel_line": 1565,
      "note": ""
    },
    {
      "line_index": 9,
      "role": "riko",
      "text": "あ、あっ、んぅ——あっ——ん、んっ",
      "skip_synthesis": false,
      "novel_line": 1571,
      "note": ""
    },
    {
      "line_index": 10,
      "role": "riko",
      "text": "ぁ……あったかい……もっと",
      "skip_synthesis": false,
      "novel_line": 1587,
      "note": ""
    },
    {
      "line_index": 11,
      "role": "riko",
      "text": "んっ、ああ……出てる……イきながら、出されてる",
      "skip_synthesis": false,
      "novel_line": 1597,
      "note": ""
    },
    {
      "line_index": 12,
      "role": "riko",
      "text": "あっ……剛さ……っ",
      "skip_synthesis": false,
      "novel_line": 1607,
      "note": ""
    },
    {
      "line_index": 13,
      "role": "riko",
      "text": "あっ……いっぱい……おなか……ぱんぱん",
      "skip_synthesis": false,
      "novel_line": 1615,
      "note": ""
    },
    {
      "line_index": 14,
      "role": "riko",
      "text": "もう入んない……のに、もっと欲しい",
      "skip_synthesis": false,
      "novel_line": 1619,
      "note": ""
    },
    {
      "line_index": 15,
      "role": "riko",
      "text": "もっと",
