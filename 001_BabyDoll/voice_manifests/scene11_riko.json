      "note": "非莉子セリフ（スキップ）"
    },
    {
      "line_index": 2,
      "role": "riko",
      "text": "……大丈夫。あたしが嫌だったら、ちゃんと言う。——でも、まだ言わない",
      "skip_synthesis": false,
      "novel_line": 1523,
      "note": ""
    },
    {
      "line_index": 3,
      "role": "riko",
      "text": "……五人、全員。あたし一人に",
      "skip_synthesis": false,
      "novel_line": 1535,
      "note": ""
    },
    {
      "line_index": 4,
      "role": "riko",
      "text": "……来て",
      "skip_synthesis": false,
      "novel_line": 1539,
      "note": ""
    },
    {
      "line_index": 5,
      "role": "riko",
      "text": "んっ——あ——っ！",
      "skip_synthesis": false,
      "novel_line": 1551,
      "note": ""
    },
    {
      "line_index": 6,
      "role": "riko",
      "text": "中にっ……出してっ",
      "skip_synthesis": false,
      "novel_line": 1561,
      "note": ""
    },
    {
      "line_index": 7,
      "role": "riko",
      "text": "もっとちょうだい",
