      "skip_synthesis": false,
      "novel_line": 769,
      "note": ""
    },
    {
      "line_index": 18,
      "role": "riko",
      "text": "あ、あっ、あっ——タクミさ、あたしまた——あたしまたイっちゃう——！",
      "skip_synthesis": false,
      "novel_line": 773,
      "note": ""
    },
    {
      "line_index": 19,
      "role": "riko",
      "text": "タクミさ、中、中にっ……ちょうだいっ……!",
      "skip_synthesis": false,
      "novel_line": 777,
      "note": ""
    },
    {
      "line_index": 20,
      "role": "riko",
