      "novel_line": 713,
      "note": ""
    },
    {
      "line_index": 8,
      "role": "riko",
      "text": "ん……ぁ……入って、きた",
      "skip_synthesis": false,
      "novel_line": 719,
      "note": ""
    },
    {
      "line_index": 9,
      "role": "riko",
      "text": "あ……ふかい……涼さん、おく、おく当たって",
      "skip_synthesis": false,
      "novel_line": 725,
      "note": ""
    },
    {
      "line_index": 10,
      "role": "riko",
      "text": "あっ、あっ、きもちいい、きもちいいよぉ——涼さん、奥、気持ちいい——!",
      "skip_synthesis": false,
      "novel_line": 733,
      "note": ""
    },
    {
      "line_index": 11,
      "role": "riko",
      "text": "あっ、あっ——あたし、また来ちゃ——あっ、また——！",
      "skip_synthesis": false,
      "novel_line": 737,
      "note": ""
    },
    {
      "line_index": 12,
      "role": "riko",
      "text": "涼さん……中に……いっぱい出して",
      "skip_synthesis": false,
      "novel_line": 743,
      "note": ""
    },
    {
      "line_index": 13,
      "role": "riko",
      "text": "あっ……! 中に、出てる……涼さんの、あたしの中に",
      "skip_synthesis": false,
      "novel_line": 749,
      "note": ""
    },
    {
      "line_index": 14,
      "role": "riko",
      "text": "ま、まって、今イったばっか",
      "skip_synthesis": false,
      "novel_line": 759,
      "note": ""
    },
    {
      "line_index": 15,
      "role": "riko",
      "text": "待たねぇよ",
      "skip_synthesis": false,
      "novel_line": 761,
      "note": ""
    },
    {
      "line_index": 16,
      "role": "riko",
      "text": "あっ——! ……涼さんのが中にあるのに……ぐちゅって、した",
      "skip_synthesis": false,
      "novel_line": 765,
      "note": ""
    },
    {
      "line_index": 17,
      "role": "riko",
