      "skip_synthesis": false,
      "novel_line": 695,
      "note": ""
    },
    {
      "line_index": 4,
      "role": "riko",
      "text": "あ、あっ、あっ——涼さん、ダメっ、指だけで、あたし、もう",
      "skip_synthesis": false,
      "novel_line": 701,
      "note": ""
    },
    {
      "line_index": 5,
      "role": "riko",
      "text": "あ、あぁっ……! ん、んんっ……!",
      "skip_synthesis": false,
      "novel_line": 705,
      "note": ""
    },
    {
      "line_index": 6,
      "role": "other",
      "text": "莉子ちゃん、入れていい？",
