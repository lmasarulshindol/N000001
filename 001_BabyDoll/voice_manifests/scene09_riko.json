      "novel_line": 1299,
      "note": ""
    },
    {
      "line_index": 8,
      "role": "riko",
      "text": "はぁっ——！　あ、あっ、タクミさ——速い——！",
      "skip_synthesis": false,
      "novel_line": 1307,
      "note": ""
    },
    {
      "line_index": 9,
      "role": "riko",
      "text": "あっ——！",
      "skip_synthesis": false,
      "novel_line": 1315,
      "note": ""
    },
    {
      "line_index": 10,
      "role": "riko",
      "text": "あ、あ、あっ、蓮——またっ",
      "skip_synthesis": false,
      "novel_line": 1323,
      "note": ""
    },
    {
      "line_index": 11,
      "role": "riko",
      "text": "あ、あ、あっ、タクミさ——またっ——！",
      "skip_synthesis": false,
      "novel_line": 1329,
      "note": ""
    },
    {
      "line_index": 12,
      "role": "riko",
      "text": "中にっ……出してっ……もっと、もっとちょうだいっ",
      "skip_synthesis": false,
      "novel_line": 1335,
      "note": ""
    },
    {
      "line_index": 13,
      "role": "riko",
      "text": "あっ……蓮……出して、あたしの中に……ぜんぶ",
      "skip_synthesis": false,
      "novel_line": 1341,
      "note": ""
    },
    {
      "line_index": 14,
      "role": "riko",
      "text": "あっ……出てる……あったかい……もっと",
      "skip_synthesis": false,
      "novel_line": 1345,
      "note": ""
    },
    {
      "line_index": 15,
      "role": "riko",
      "text": "んっ——！",
      "skip_synthesis": false,
      "novel_line": 1349,
      "note": ""
    },
    {
      "line_index": 16,
      "role": "riko",
      "text": "あっ——！　また、入って",
      "skip_synthesis": false,
      "novel_line": 1355,
      "note": ""
    },
    {
      "line_index": 17,
      "role": "riko",
      "text": "んぁっ……また、きた……おなか、いっぱいなのに……まだ欲しい",
      "skip_synthesis": false,
      "novel_line": 1359,
      "note": ""
    },
    {
      "line_index": 18,
      "role": "riko",
      "text": "あっ、あっ、止まらな——またイっ——！",
      "skip_synthesis": false,
      "novel_line": 1367,
      "note": ""
    },
    {
      "line_index": 19,
      "role": "riko",
      "text": "いっ……！　ふとい……中、ぱんぱん",
      "skip_synthesis": false,
      "novel_line": 1381,
      "note": ""
    },
    {
      "line_index": 20,
      "role": "riko",
      "text": "あ……っ、あ……っ",
      "skip_synthesis": false,
      "novel_line": 1389,
      "note": ""
    },
    {
      "line_index": 21,
      "role": "riko",
      "text": "剛さ……中に……ぜんぶ出して……あたしの中、ぜんぶ剛さんので",
      "skip_synthesis": false,
      "novel_line": 1393,
      "note": ""
    },
    {
      "line_index": 22,
      "role": "riko",
      "text": "あっ、ああっ——！　いっぱい、出てる、止まらない——！　あたしの中、あふれ",
