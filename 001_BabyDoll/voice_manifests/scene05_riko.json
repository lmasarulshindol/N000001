  "items": [
    {
      "line_index": 1,
      "role": "riko",
      "text": "……涼、さん……？　よなか……なのに",
      "skip_synthesis": false,
      "novel_line": 847,
      "note": ""
    },
    {
      "line_index": 2,
      "role": "other",
      "text": "……眠れなくて。莉子ちゃんのこと、考えてた",
      "skip_synthesis": true,
      "novel_line": 851,
      "note": "非莉子セリフ（スキップ）"
    },
    {
      "line_index": 3,
      "role": "riko",
      "text": "考えてた……って、何を？",
      "skip_synthesis": false,
      "novel_line": 855,
      "note": ""
    },
    {
      "line_index": 4,
      "role": "other",
      "text": "……さっきの3P、俺、仕事モードだっただろ。ちゃんと触れてなかった気がして",
      "skip_synthesis": true,
      "novel_line": 857,
      "note": "非莉子セリフ（スキップ）"
    },
    {
      "line_index": 5,
      "role": "riko",
      "text": "……涼さん、昼間と、ぜんぜん違う。夜は、やさしいんだね",
      "skip_synthesis": false,
      "novel_line": 865,
      "note": ""
    },
    {
      "line_index": 6,
      "role": "other",
      "text": "……昼間は仕事だから。今は",
      "skip_synthesis": true,
      "novel_line": 869,
      "note": "非莉子セリフ（スキップ）"
    },
    {
      "line_index": 7,
      "role": "riko",
      "text": "……今は？",
      "skip_synthesis": false,
      "novel_line": 875,
      "note": ""
    },
    {
      "line_index": 8,
      "role": "other",
      "text": "……今は、ただ、触りたかっただけ",
      "skip_synthesis": true,
      "novel_line": 877,
      "note": "非莉子セリフ（スキップ）"
    },
    {
      "line_index": 9,
      "role": "riko",
      "text": "ん……涼さん、キス、やさしい",
      "skip_synthesis": false,
      "novel_line": 887,
      "note": ""
    },
    {
      "line_index": 10,
      "role": "riko",
      "text": "あ……手、あったかい……全部、さわるんだね",
      "skip_synthesis": false,
      "novel_line": 893,
      "note": ""
    },
    {
      "line_index": 11,
      "role": "other",
      "text": "うん。全部",
      "skip_synthesis": true,
      "novel_line": 895,
      "note": "非莉子セリフ（スキップ）"
    },
    {
      "line_index": 12,
      "role": "riko",
      "text": "ぁ……涼さん",
      "skip_synthesis": false,
      "novel_line": 903,
      "note": ""
    },
    {
      "line_index": 13,
      "role": "riko",
      "text": "ん……きもちいい……昼間と、ぜんぜん違う……涼さん、こんなの、ずるい",
      "skip_synthesis": false,
      "novel_line": 911,
      "note": ""
    },
    {
      "line_index": 14,
      "role": "riko",
      "text": "あ……手、つないだまま……ん",
      "skip_synthesis": false,
      "novel_line": 915,
      "note": ""
    },
    {
      "line_index": 15,
      "role": "riko",
      "text": "あ……涼さ……あたし、ゆっくり……来てる……来てるのに、終わらない",
      "skip_synthesis": false,
      "novel_line": 923,
      "note": ""
    },
    {
      "line_index": 16,
      "role": "other",
      "text": "……出すよ。中に",
      "skip_synthesis": true,
      "novel_line": 937,
      "note": "非莉子セリフ（スキップ）"
    },
    {
      "line_index": 17,
      "role": "riko",
      "text": "……出して。涼さんの、あたしの中に……ぜんぶ、ちょうだい……手、離さないで",
      "skip_synthesis": false,
      "novel_line": 939,
      "note": ""
    },
    {
      "line_index": 18,
      "role": "riko",
      "text": "……あったかい。涼さんの",
      "skip_synthesis": false,
      "novel_line": 949,
      "note": ""
    },
    {
      "line_index": 19,
      "role": "riko",
      "text": "……涼さん。昼間もこうして",
      "skip_synthesis": false,
      "novel_line": 953,
      "note": ""
    },
    {
      "line_index": 20,
      "role": "other",
      "text": "……昼間は、仕事の顔に戻る。ごめんな",
      "skip_synthesis": true,
      "novel_line": 955,
      "note": "非莉子セリフ（スキップ）"
    },
    {
      "line_index": 21,
      "role": "riko",
      "text": "……いいよ。夜の涼さんを、あたしだけ知ってるってことでしょ",
      "skip_synthesis": false,
      "novel_line": 957,
      "note": ""
    },
    {
      "line_index": 22,
      "role": "riko",
      "text": "……ゆっくりなの、すき",
      "skip_synthesis": false,
      "novel_line": 961,
      "note": ""
    }
  ]
