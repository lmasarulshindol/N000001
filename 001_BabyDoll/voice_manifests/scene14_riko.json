  "items": [
    {
      "line_index": 1,
      "role": "riko",
      "text": "最後だね。あたし、この三日間——楽しかった。全部",
      "skip_synthesis": false,
      "novel_line": 1875,
      "note": ""
    },
    {
      "line_index": 2,
      "role": "riko",
      "text": "……最後は、あたしが選ぶ。一人ずつ",
      "skip_synthesis": false,
      "novel_line": 1879,
      "note": ""
    },
    {
      "line_index": 3,
      "role": "riko",
      "text": "タクミさん。BBQのお肉、おいしかった",
      "skip_synthesis": false,
      "novel_line": 1887,
      "note": ""
    },
    {
      "line_index": 4,
      "role": "riko",
      "text": "……こっちのお肉もね",
      "skip_synthesis": false,
      "novel_line": 1891,
      "note": ""
    },
    {
      "line_index": 5,
      "role": "other",
      "text": "お前、ほんと生意気だな",
      "skip_synthesis": true,
      "novel_line": 1895,
      "note": "非莉子セリフ（スキップ）"
    },
    {
      "line_index": 6,
      "role": "riko",
      "text": "……ん。タクミさんの味、覚えた",
      "skip_synthesis": false,
      "novel_line": 1905,
      "note": ""
    },
    {
      "line_index": 7,
      "role": "riko",
      "text": "涼さん。……昼間の涼さんも、夜の涼さんも、どっちも好き",
      "skip_synthesis": false,
      "novel_line": 1911,
      "note": ""
    },
    {
      "line_index": 8,
      "role": "other",
      "text": "……ありがとう",
      "skip_synthesis": true,
      "novel_line": 1917,
      "note": "非莉子セリフ（スキップ）"
    },
    {
      "line_index": 9,
      "role": "riko",
      "text": "あっ……涼さ……っ",
      "skip_synthesis": false,
      "novel_line": 1921,
      "note": ""
    },
    {
      "line_index": 10,
      "role": "riko",
      "text": "あ——涼さっ",
      "skip_synthesis": false,
      "novel_line": 1927,
      "note": ""
    },
    {
      "line_index": 11,
      "role": "riko",
      "text": "涼さん……中に、ぜんぶ……ね？",
      "skip_synthesis": false,
      "novel_line": 1931,
      "note": ""
    },
    {
      "line_index": 12,
      "role": "riko",
      "text": "……ん。涼さん……昼間も夜も好き",
      "skip_synthesis": false,
      "novel_line": 1937,
      "note": ""
    },
    {
      "line_index": 13,
      "role": "riko",
      "text": "蓮くん。……昨夜は、ありがとう",
      "skip_synthesis": false,
      "novel_line": 1943,
      "note": ""
    },
    {
      "line_index": 14,
      "role": "riko",
      "text": "……お前に言われると、なんか変な感じ",
      "skip_synthesis": false,
      "novel_line": 1947,
      "note": ""
    },
    {
      "line_index": 15,
      "role": "riko",
      "text": "全力出して。最後だから",
      "skip_synthesis": false,
      "novel_line": 1949,
      "note": ""
    },
    {
      "line_index": 16,
      "role": "riko",
      "text": "ん……蓮くんの、あつい",
      "skip_synthesis": false,
      "novel_line": 1957,
      "note": ""
    },
    {
      "line_index": 17,
      "role": "riko",
      "text": "剛さん。……いっぱい、ちょうだい。最後だから。あたしの中、剛さんので、いっぱいにして",
      "skip_synthesis": false,
      "novel_line": 1965,
      "note": ""
    },
    {
      "line_index": 18,
      "role": "riko",
      "text": "んっ、ああ……剛さんの、いつも、いっぱい……もう、おなか、ぱんぱん……しあわせ",
      "skip_synthesis": false,
      "novel_line": 1979,
      "note": ""
    },
    {
      "line_index": 19,
      "role": "riko",
      "text": "しあわせ",
      "skip_synthesis": false,
      "novel_line": 1981,
      "note": ""
    },
    {
      "line_index": 20,
      "role": "riko",
      "text": "おにいさん。最後",
      "skip_synthesis": false,
      "novel_line": 1993,
      "note": ""
    },
    {
      "line_index": 21,
      "role": "riko",
      "text": "……ありがとう。いちばん最初の人で、いちばん最後の人",
      "skip_synthesis": false,
      "novel_line": 1997,
      "note": ""
    },
    {
      "line_index": 22,
      "role": "riko",
      "text": "……何回、出してもらったんだろ。……わかんない。途中から、数えるのやめちゃった",
      "skip_synthesis": false,
      "novel_line": 2007,
      "note": ""
    },
    {
      "line_index": 23,
      "role": "riko",
      "text": "……あたし、壊れてないよ。数えらんなくなっても、『もっとちょうだい』って言ってても。……壊れてない。ちゃんと、あたしのまま",
      "skip_synthesis": false,
      "novel_line": 2011,
      "note": ""
    }
  ]
}